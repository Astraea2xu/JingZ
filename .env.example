# 文本模型：用于创意、剧本、角色与分镜
# 可直接使用火山方舟兼容 Chat Completions 的模型
JINGZHOU_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
JINGZHOU_API_KEY=
JINGZHOU_MODEL=doubao-seed-2-0-lite-260215
JINGZHOU_TIMEOUT=120

# 图片模型：用于角色定妆图、场景概念图和分镜固定帧
# IMAGE_API_BASE_URL 填写完整的 OpenAI 兼容图片生成地址
IMAGE_API_BASE_URL=https://api.openai.com/v1/images/generations
IMAGE_API_KEY=
IMAGE_MODEL=

# 图片编辑模型：用于修改现有角色图和场景图
# 必须填写完整的 OpenAI 兼容 /images/edits 地址，程序不会补全路径
# KEY 和 MODEL 留空时分别复用 IMAGE_API_KEY 与 IMAGE_MODEL
IMAGE_EDIT_API_BASE_URL=https://api.openai.com/v1/images/edits
IMAGE_EDIT_API_KEY=
IMAGE_EDIT_MODEL=

# OpenAI 兼容视觉理解接口：用于从角色参考图生成角色设定
# BASE URL 填写 API 根地址，程序调用其 /chat/completions
# KEY 留空时依次复用 IMAGE_API_KEY、JINGZHOU_API_KEY
# 必须使用支持 image_url 的多模态模型，不能填写 DeepSeek 纯文本模型
VISION_API_BASE_URL=https://api.177911.com/v1
VISION_API_KEY=
VISION_MODEL=

# 自部署 DeepSeek-VL2（服务需暴露 OpenAI 兼容 /v1/chat/completions）示例：
# VISION_API_BASE_URL=http://127.0.0.1:8000/v1
# VISION_API_KEY=EMPTY
# VISION_MODEL=deepseek-ai/deepseek-vl2-tiny

# 旧版 JINGZHOU_IMAGE_MODEL 仍兼容；未填写 IMAGE_API_KEY 时复用文本模型 Key
JINGZHOU_IMAGE_MODEL=

# Seedance 视频接口：必须填写中转站的完整任务创建地址
# 程序不会补全、替换或猜测 BASE URL
VIDEO_API_BASE_URL=https://api.177911.com/v1/video/generations
# 仅当任务成功响应没有视频 URL 时，用于下载 /{task_id}/content
VIDEO_CONTENT_API_BASE_URL=https://api.177911.com/v1/videos
VIDEO_API_KEY=
VIDEO_MODEL=doubao-seedance-2-0-260128
VIDEO_POLL_INTERVAL=10
VIDEO_API_TIMEOUT=120
VIDEO_API_RETRIES=4
VIDEO_DOWNLOAD_MAX_MB=600
VIDEO_DOWNLOAD_RETRIES=4

# 旧版 SEEDANCE_* 配置仍可继续使用，VIDEO_* 的优先级更高

# 可选：填写 ffmpeg.exe 的完整路径；若已加入 PATH 可留空
FFMPEG_PATH=
